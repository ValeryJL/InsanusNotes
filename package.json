{
  "name": "insanusnotes",
  "version": "1.0.0",
  "description": "A note-taking app for programmers, built around OOP concepts, for world-building and storytelling.",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "package": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.insanus.notes",
    "productName": "InsanusNotes",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
